{
  "servers": {
    "company-api-docs": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/clfy1125/turnflow_backend#subdirectory=api-mcp",
        "company-api-mcp"
      ],
      "env": {
        "OPENAPI_URL": "https://dev-api.turnflow.link/api/schema/"
      }
    }
  }
}
