# Django Settings
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
DJANGO_SETTINGS_MODULE=config.settings.local

# Database (PostgreSQL)
DB_NAME=instagram_service
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=db
DB_PORT=5432

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Application
WEB_PORT=8000
ALLOWED_HOSTS=localhost,127.0.0.1

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Instagram API (추후 설정)
# INSTAGRAM_APP_ID=
# INSTAGRAM_APP_SECRET=
# INSTAGRAM_REDIRECT_URI=

# TikTok Business API (business-api.tiktok.com)
# 스코프: Ad Comments + TikTok Accounts. 광고 댓글 모더레이션 + blockedword 관리.
TIKTOK_MOCK_MODE=True
# TIKTOK_BUSINESS_APP_ID=
# TIKTOK_BUSINESS_APP_SECRET=
# TIKTOK_BUSINESS_REDIRECT_URI=https://turnflow-api.clfy.ai.kr/api/v1/tiktok/integration/connect/callback/

# YouTube / Google OAuth (Data API v3)
# 기본 일일 quota = 10,000 units. videos.insert = 1,600 units/회.
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=
YOUTUBE_MOCK_MODE=True
# YOUTUBE_DAILY_QUOTA=10000

# TossPayments 빌링(정기결제)
# 개발자센터(https://developers.tosspayments.com) → API 키에서 확인. test_* 키는 실과금 없음.
# 라이브 전환: 자동결제(빌링) 계약 승인 후 live_* 키로 교체 + 웹훅 URL 등록.
# TOSS_SECRET_KEY=test_sk_...
# TOSS_CLIENT_KEY=test_ck_...
# TOSS_API_BASE=https://api.tosspayments.com
# 카드번호 직접 입력 dev 헬퍼 API (Swagger 단독 검증용). 운영에서는 반드시 False.
# TOSS_DEV_CARD_AUTH_ENABLED=False

# Telegram 운영 알림 (토큰 refresh / 장애)
# 봇 생성: @BotFather → /newbot → 토큰 발급
# chat_id: 봇에게 메시지 보낸 후 https://api.telegram.org/bot<TOKEN>/getUpdates 에서 확인
# 둘 다 비우면 알림 비활성 (개발 안전)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Insights API kill-switch
# False (기본) 시 /api/v1/insights/* 가 503 으로 차단되고 관련 celery beat 도 멈춤.
# 출시 시점에 True 로 켜면 됨. (manage_insights OAuth scope 도 같이 복원해야 함)
INSIGHTS_API_ENABLED=False

# Coupang Partners Open API
# 쿠팡 파트너스(어필리에이트) Open API — 상품 검색 / 가격 / 딥링크 조회
# 발급: https://partners.coupang.com → 도구 → API 키 발급
COUPANG_MOCK_MODE=True
# COUPANG_PARTNERS_ACCESS_KEY=
# COUPANG_PARTNERS_SECRET_KEY=

# 외부 링크 메타 스크랩 (link/fetch-meta) — anti-bot 폴백
# 오늘의집/스마트스토어 등 직접 fetch 가 403 으로 막히는 사이트용. 미설정 시 폴백 비활성.
# provider: scraperapi | scrapingbee  (대상 HTML 을 그대로 돌려주는 서비스)
# LINK_SCRAPER_PROVIDER=scraperapi
# LINK_SCRAPER_API_KEY=
# LINK_SCRAPER_RENDER_JS=True
# LINK_SCRAPER_COUNTRY=kr
# LINK_SCRAPER_TIMEOUT=20
# Akamai 우회 프리미엄 플래그 (provider 문서 참고). scraperapi: "ultra_premium=true", scrapingbee: "stealth_proxy=true"
# LINK_SCRAPER_EXTRA_PARAMS=ultra_premium=true

# Security (Production)
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True

# CORS (개발용)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Cloudflare Tunnel (개발 서버 공개 — ngrok 대체)
# dev-api.turnflow.link -> Cloudflare edge -> cloudflared -> docker web:8000
# Zero Trust 대시보드에서 named tunnel 생성 후 토큰 붙여넣기. 자세한 셋업: CLOUDFLARE_TUNNEL_SETUP.md
# 공개 URL 사용 시 ALLOWED_HOSTS/CORS_ALLOWED_ORIGINS/CSRF_TRUSTED_ORIGINS 에 dev-api.turnflow.link 추가 필요.
# CLOUDFLARE_TUNNEL_TOKEN=

# AI 레퍼런스 페이지 스냅샷 캡쳐 대상 (프론트 공개 페이지)
# 실서버: https://turnflow.link, 개발: ngrok 도메인 (예: https://quotable-thorn-relieve.ngrok-free.dev)
# 미지정 시 FRONTEND_URL 로 폴백.
# SNAPSHOT_BASE_URL=https://turnflow.link
# FRONTEND_URL=http://localhost:3000

# Logging
LOG_LEVEL=INFO

# 미인증 계정 정리 배치 (authentication.cleanup_unverified_accounts, 매일 KST 04:00)
# 비가역 삭제이므로 기본 비활성 + dry-run. 운영 투입 절차:
#   1) UNVERIFIED_ACCOUNT_CLEANUP_ENABLED=True + DRY_RUN=True 로 후보 로그 며칠 관찰
#   2) 안전 확인 후 UNVERIFIED_ACCOUNT_CLEANUP_DRY_RUN=False 로 실삭제 전환
# 관리자/워크스페이스 소유자/소셜 로그인 계정은 항상 제외된다.
# UNVERIFIED_ACCOUNT_CLEANUP_ENABLED=False
# UNVERIFIED_ACCOUNT_CLEANUP_DRY_RUN=True
# UNVERIFIED_ACCOUNT_RETENTION_DAYS=1

# 랜딩 방문 트래킹 (apps.analytics — POST /api/v1/track/visit/, 공개 비콘)
# THROTTLE_TRACK_VISIT: IP당 방문 기록 스로틀. 한국 모바일 CGNAT(수백 명이 한 IP 공유) 특성상
#   과도하게 조이면 실사용 방문이 유실됨 — 실질 어뷰즈 방어는 visitor_id당 시간당 캡이 담당.
# LANDING_VISIT_RETENTION_DAYS: LandingVisit 원시 행 보존일 — 초과분은 매일 KST 03:30 배치 삭제
#   (analytics.cleanup_landing_visits). 가입 귀속(SignupAttribution)은 TTL 없음.
# ⚠️ 운영: 랜딩 오리진(예: https://turnflow.link)을 CORS_ALLOWED_ORIGINS 에 추가해야 비콘이 동작함.
# THROTTLE_TRACK_VISIT=120/hour
# LANDING_VISIT_RETENTION_DAYS=180
# TRACK_VISIT_MAX_WRITES_PER_VISITOR_HOUR=6

# 댓글 웹훅 누락 보정 (integrations.poll_missed_comments, 매시간)
# comments 웹훅 유실 대비 — specific_media 캠페인 게시물의 최근 댓글을 재조회해 누락 DM 보정.
# 본문 미저장, comment_id 최소 장부(SeenComment)만 TTL 보관. 발송량은 rate_governor 가 throttle.
# MISSED_COMMENT_POLL_ENABLED=True
# MISSED_COMMENT_LEDGER_TTL_DAYS=10
# PRIVATE_REPLY_WINDOW_DAYS=7
# MISSED_COMMENT_POLL_PAGE_SIZE=50
# MISSED_COMMENT_POLL_MAX_PAGES=20
# MISSED_COMMENT_POLL_MAX_TARGETS=1000
