# TurnFlow DR — GCP cold-VM 설정. 복사해서 gcp.env 로 쓰고 값 채울 것 (gcp.env 는 .gitignore).
#   cp gcp.env.example gcp.env && $EDITOR gcp.env
# 모든 deploy/dr/gcp/*.sh 가 이 파일을 source 한다. 비밀값(토큰/키)은 여기 두지 말고 Secret Manager 로.

# ── GCP 프로젝트/리전 ─────────────────────────────────────────────
GCP_PROJECT="__your-gcp-project-id__"
GCP_REGION="asia-northeast3"          # 서울
GCP_ZONE="asia-northeast3-a"

# ── DR VM 사양 ────────────────────────────────────────────────────
VM_NAME="turnflow-dr"
MACHINE_TYPE="e2-standard-8"          # 8 vCPU / 32GB (prod 동급). 비상 최소: e2-standard-4(16GB)+dr-overlay
DISK_SIZE="300GB"                     # 복원 DB(월 ~120GB 증가) + WAL 여유 + 새 full backup 스테이징
DISK_TYPE="pd-ssd"                    # WAL 재생이 I/O 바운드 → SSD
IMAGE_FAMILY="ubuntu-2204-lts"
IMAGE_PROJECT="ubuntu-os-cloud"

# ── 네트워크/접근 ─────────────────────────────────────────────────
NETWORK_TAG="turnflow-dr"             # 방화벽 룰 타겟 태그
STATIC_IP_NAME="turnflow-dr-ip"       # 예약 정적 외부 IP 이름(프로비저닝 시 생성/조회)
OPERATOR_CIDR="__your.ip.addr.0/32__" # SSH(22) 허용 CIDR — 당신 사무실/집 공인 IP

# ── 서비스 계정(최소권한) ─────────────────────────────────────────
SA_NAME="turnflow-dr-sa"
# SA_EMAIL 는 스크립트가 ${SA_NAME}@${GCP_PROJECT}.iam.gserviceaccount.com 로 유도

# ── 레포(핀 고정) ─────────────────────────────────────────────────
REPO_URL="https://github.com/clfy1125/turnflow_backend.git"
GIT_REF="__colo-deployed-commit-sha__"   # 콜로가 현재 돌리는 정확한 커밋 SHA(브랜치 아님!). 콜로: git rev-parse HEAD

# ── Cloudflare(DNS 스왑) ──────────────────────────────────────────
CF_ZONE_NAME="clfy.ai.kr"                       # 영역(존) 이름 — api.turnflow.clfy.ai.kr 의 상위 존
CF_RECORD_NAME="api.turnflow.clfy.ai.kr"        # 스왑 대상 A 레코드
COLO_IP="__colo-public-ip__"                    # 평상시/failback 시 되돌릴 콜로 공인 IP

# ── 앱/헬스 ───────────────────────────────────────────────────────
ORIGIN="https://api.turnflow.clfy.ai.kr"

# ── Secret Manager 시크릿 이름(값 아님 — setup_secrets.sh 가 채움) ──
SEC_ENV_PROD="turnflow-dr-env-production"   # .env.production (SITE_ID=gcp)
SEC_PGBACKREST="turnflow-dr-pgbackrest-conf" # pgbackrest.conf (R2 read 키 + cipher)
SEC_ENV_BACKUP="turnflow-dr-env-backup"     # .env.backup (dump 폴백용; 선택)
SEC_CF_CERT="turnflow-cf-origin-cert"       # CF Origin Certificate (PEM)
SEC_CF_KEY="turnflow-cf-origin-key"         # CF Origin cert 개인키 (PEM)
SEC_CF_TOKEN="turnflow-cf-api-token"        # CF API 토큰(Zone.DNS:Edit, 단일 존)

# ── Cloudflare 엣지 IP CIDR(방화벽 443 허용; deploy/caddy/Caddyfile 와 동일 목록) ──
CF_CIDRS="173.245.48.0/20,103.21.244.0/22,103.22.200.0/22,103.31.4.0/22,141.101.64.0/18,108.162.192.0/18,190.93.240.0/20,188.114.96.0/20,197.234.240.0/22,198.41.128.0/17,162.158.0.0/15,104.16.0.0/13,104.24.0.0/14,172.64.0.0/13,131.0.72.0/22"
