# GCP DR Caddyfile — colo deploy/caddy/Caddyfile 의 api 블록 + **CF Origin cert(tls 명시)**.
# 콜로와 차이: (1) tls /certs/origin.pem /certs/origin.key (자동 ACME 불가 — CF 프록시+80 잠금) (2) llm/monitor 블록 제거.
# ⚠️ colo Caddyfile 의 api 라우팅이 바뀌면 여기도 동기화할 것(드리프트 주의).

{
	servers {
		trusted_proxies static 173.245.48.0/20 103.21.244.0/22 103.22.200.0/22 103.31.4.0/22 141.101.64.0/18 108.162.192.0/18 190.93.240.0/20 188.114.96.0/20 197.234.240.0/22 198.41.128.0/17 162.158.0.0/15 104.16.0.0/13 104.24.0.0/14 172.64.0.0/13 131.0.72.0/22 2400:cb00::/32 2606:4700::/32 2803:f800::/32 2405:b500::/32 2405:8100::/32 2a06:98c0::/29 2c0f:f248::/32
		client_ip_headers Cf-Connecting-Ip X-Forwarded-For
		max_header_size 32KB
		timeouts {
			read_header 10s
			idle 60s
		}
		protocols h1 h2
	}
}

turnflow-api.clfy.ai.kr {
	encode zstd gzip

	# CF Origin Certificate — CF Full(strict) 가 신뢰. 자동 ACME 대체.
	tls /certs/origin.pem /certs/origin.key

	header {
		-Server
		X-Content-Type-Options nosniff
		Referrer-Policy strict-origin-when-cross-origin
	}

	@bad_method {
		not method GET POST PUT PATCH DELETE OPTIONS HEAD
	}
	handle @bad_method {
		respond "Method Not Allowed" 405
	}

	# 헬스 → web_dashboard (CF/모니터 일관)
	@health path /api/v1/healthz /api/v1/healthz/live /api/v1/healthz/ready /api/v1/healthz/diag
	handle @health {
		reverse_proxy web_dashboard:8000
	}

	@maint_health path /maintenance-health
	handle @maint_health {
		respond "OK" 200
	}

	# Tier 1: Instagram 웹훅 → web_webhook
	@webhook path /api/v1/integrations/instagram/webhook /api/v1/integrations/instagram/webhook/*
	handle @webhook {
		request_body {
			max_size 512KB
		}
		reverse_proxy web_webhook:8000
	}

	# Tier 3: external-IO → web_external
	@external path /api/v1/link/* /api/v1/pages/ai/* /api/v1/ai/* /api/v1/pages/products/coupang/lookup /api/v1/pages/products/coupang/lookup/ /api/v1/integrations/instagram/*/test*
	handle @external {
		request_body {
			max_size 30MB
		}
		reverse_proxy web_external:8000
	}

	# Tier 2: auth
	@auth path /api/v1/auth/*
	handle @auth {
		request_body {
			max_size 128KB
		}
		reverse_proxy web_dashboard:8000
	}

	# Tier 2: 미디어 업로드
	@media path /api/v1/pages/me/media /api/v1/pages/me/media/* /api/v1/pages/multipages/*/media /api/v1/pages/multipages/*/media/*
	handle @media {
		request_body {
			max_size 30MB
		}
		reverse_proxy web_dashboard:8000
	}

	# 기본 → web_dashboard
	handle {
		request_body {
			max_size 5MB
		}
		reverse_proxy web_dashboard:8000
	}
}
