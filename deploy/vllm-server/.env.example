# /root/vllm-server/.env (이 파일을 .env 로 복사해서 실제 값 채우기)
#
# 절대 git 에 커밋 금지! /root/vllm-server/.gitignore 에 .env 등록 권장.

# ── DeepSeek API ──────────────────────────────────────────
# https://platform.deepseek.com/api_keys 에서 발급
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── (선택) 향후 다른 프로바이더 추가 시 ────────────────────
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
