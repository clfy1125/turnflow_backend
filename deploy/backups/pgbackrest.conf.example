# GATE-0 / Layer 2 — pgBackRest config for WAL archiving + PITR to Cloudflare R2.
# Install at /etc/pgbackrest/pgbackrest.conf on the host. Chosen over wal-g for
# integrated backup+WAL+retention+verification (`pgbackrest check`) in one tool.
#
# RPO ≈ seconds–minutes (archive_timeout=60 ships a partial segment each minute).
# RTO ≈ tens of minutes (restore last base backup + replay WAL to target time/LSN).
#
# pgBackRest runs INSIDE the db container (image = deploy/backups/Dockerfile.db), because
# Postgres executes archive_command as its own subprocess — so the binary must be there,
# and a host-built (glibc) binary can't run in this musl/alpine image anyway.
# Install this file at /etc/pgbackrest/pgbackrest.conf via the compose bind-mount
# (./deploy/backups/pgbackrest.conf -> /etc/pgbackrest/pgbackrest.conf:ro).
# Drive backup/check with:  docker compose -f docker-compose.prod.yml exec -u postgres db pgbackrest ...

[global]
repo1-type=s3
repo1-s3-endpoint=__R2_ACCOUNT_ID__.r2.cloudflarestorage.com
repo1-s3-bucket=turnflow-db-backups
repo1-s3-region=auto
repo1-s3-uri-style=path
repo1-s3-key=__SCOPED_DB_BACKUP_KEY__
repo1-s3-key-secret=__SCOPED_DB_BACKUP_SECRET__
repo1-path=/pgbackrest
# Client-side encryption — R2 stores only ciphertext (matches PGBACKREST_CIPHER_PASS in .env.backup).
repo1-cipher-type=aes-256-cbc
repo1-cipher-pass=__LONG_RANDOM_PASSPHRASE__
repo1-retention-full=2
repo1-retention-diff=6
# WAL(아카이브) 보존 — 이걸 명시 안 하면 버전에 따라 "WAL 미만료 + 경고"로 archive/ 가 무한 증가.
# full 2개가 커버하는 구간만 WAL 보관(약 2주 rewind), 그 이전 WAL 은 backup 종료 시 expire 가 자동 삭제.
repo1-retention-archive=2
repo1-retention-archive-type=full
process-max=4
compress-type=zst
compress-level=3
start-fast=y
log-level-console=info
log-level-file=detail

[turnflow]
# CONTAINER data dir (pgBackRest runs inside the db container). Connects to local PG
# over the unix socket as the postgres user (run exec with `-u postgres`).
pg1-path=/var/lib/postgresql/data
pg1-port=5432
pg1-socket-path=/var/run/postgresql
