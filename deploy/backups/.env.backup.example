# GATE-0 backup secrets — copy to /opt/turnflow_backend/.env.backup, then: chmod 600 .env.backup
# Kept SEPARATE from Django's .env so the app process cannot read backup credentials.

# --- Postgres (matches docker-compose.prod.yml) ---
DB_CONTAINER=turnflow_instagram_db
PGUSER=postgres
PGDATABASE=instagram_service
DB_PASSWORD=__same_as_django_.env_DB_PASSWORD__

# --- Cloudflare R2 (use a SCOPED token limited to the DB bucket, NOT the media keys) ---
R2_ACCOUNT_ID=__r2_account_id__
R2_ACCESS_KEY_ID=__scoped_db_backup_key__
R2_SECRET_ACCESS_KEY=__scoped_db_backup_secret__
R2_BUCKET_DB=turnflow-db-backups

# --- Client-side encryption ---
# Import the PUBLIC key on the box (encrypt-only). PRIVATE key stays OFF-box (password manager / recovery laptop).
#   gpg --import turnflow-backup-pub.asc
GPG_RECIPIENT=backup@turnflow.clfy.ai.kr

# --- pgBackRest (Layer 2 / WAL PITR) cipher passphrase — store here, mirror into pgbackrest.conf ---
PGBACKREST_CIPHER_PASS=__long_random_passphrase__

# --- Alerts (reuse the existing bot) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Retention knobs
LOCAL_KEEP=3
LOCAL_DIR=/opt/turnflow_backend/backups
