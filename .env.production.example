# ============================================================
# Turnflow Backend — Production Environment Variables
# 서버에서 .env.production 으로 복사 후 실제 값을 채워주세요.
# ============================================================

# Django Settings
SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_STRING
DEBUG=False
DJANGO_SETTINGS_MODULE=config.settings.prod

# Database (PostgreSQL)
DB_NAME=instagram_service
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
DB_HOST=db
DB_PORT=5432

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Hosts & Security
ALLOWED_HOSTS=api.turnflow.clfy.ai.kr
SECURE_SSL_REDIRECT=False

# CORS
CORS_ALLOWED_ORIGINS=https://link.turnflow.clfy.ai.kr
CORS_ALLOW_CREDENTIALS=True
CORS_ALLOW_ALL_ORIGINS=False

# CSRF
CSRF_TRUSTED_ORIGINS=https://api.turnflow.clfy.ai.kr,https://link.turnflow.clfy.ai.kr

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Logging
LOG_LEVEL=INFO

# Instagram API
INSTAGRAM_APP_ID=YOUR_INSTAGRAM_APP_ID
INSTAGRAM_APP_SECRET=YOUR_INSTAGRAM_APP_SECRET
INSTAGRAM_REDIRECT_URI=https://api.turnflow.clfy.ai.kr/api/v1/integrations/instagram/connect/callback/
INSTAGRAM_MOCK_MODE=False
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=YOUR_WEBHOOK_VERIFY_TOKEN

# Meta App (Facebook Login for Instagram Business)
META_APP_ID=YOUR_META_APP_ID
META_APP_SECRET=YOUR_META_APP_SECRET

# Google OAuth
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID

# OpenAI (optional)
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
