# STAGING 측정 환경 — .env.staging 으로 복사. 실서비스 시크릿 넣지 말 것(테스트 전용 더미).
# INSTAGRAM_MOCK_MODE=True 라 Meta 실호출 없음 → 서버측 처리량만 측정.

SECRET_KEY=staging-insecure-key-for-loadtest-only
DEBUG=True

DB_NAME=instagram_service
DB_USER=postgres
DB_PASSWORD=staging_test_pw

# 아래는 compose x-app-env 가 덮어씀(pgbouncer/6432 등) — 참고용.
INSTAGRAM_MOCK_MODE=True
WEBHOOK_ASYNC_MESSAGING=True

# 알림/외부연동은 비워둠(측정에 불필요)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
LLM_URL=
LLM_API_KEY=
